{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.snstac.com/tak-asset-v1.json",
  "title": "TAK Asset",
  "type": "object",
  "required": [
    "schema_version", "id", "name", "kind", "lifecycle_state", "source_id",
    "source_name", "authority", "attribution", "terms_url", "canonical_url",
    "product_ids", "domains"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "minLength": 1, "pattern": "^[^/]+$"},
    "name": {"type": "string", "minLength": 1},
    "kind": {"type": "string", "minLength": 1},
    "lifecycle_state": {"enum": ["live", "historical", "tombstone"]},
    "source_id": {"type": "string", "minLength": 1},
    "source_name": {"type": "string", "minLength": 1},
    "authority": {"type": "string", "minLength": 1},
    "attribution": {"type": "string", "minLength": 1},
    "terms_url": {"type": "string", "format": "uri"},
    "canonical_url": {"type": "string", "format": "uri"},
    "product_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "domains": {"type": "array", "uniqueItems": true, "items": {"enum": ["fire", "disaster", "usar"]}},
    "geometry": {"type": ["object", "null"]},
    "properties": {"type": "object"},
    "observed_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "first_seen_at": {"type": "string"},
    "last_seen_at": {"type": "string"},
    "retired_at": {"type": "string"},
    "expires_at": {"type": "string"},
    "links": {"type": "array"}
  }
}
